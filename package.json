{
  "name": "coroslink",
  "version": "0.1.11",
  "private": true,
  "description": "Unofficial COROS Pace Pro companion — media, watch sync, and training analytics.",
  "author": "CorosLink Contributors",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && npm run binaries:prepare && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "binaries:prepare": "node scripts/prepare-binaries.mjs",
    "binaries:prepare:win": "node scripts/prepare-binaries.mjs --platform=win32 --arch=x64",
    "binaries:prepare:linux": "node scripts/prepare-binaries.mjs --platform=linux --arch=x64",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "smoke:watch": "npm run build:electron && node scripts/smoke-watch-service.mjs",
    "test:watch-models": "npm run build:electron && node scripts/test-watch-models.mjs",
    "test:maps": "npm run build:electron && node scripts/test-maps.mjs",
    "test:greetings": "node --experimental-strip-types scripts/test-greetings.mjs",
    "start": "npm run build && electron .",
    "icons:generate": "node scripts/generate-icons.mjs",
    "rebuild": "electron-builder install-app-deps",
    "dist": "npm run binaries:prepare && npm run build && electron-builder --publish never",
    "dist:mac": "npm run binaries:prepare && npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run binaries:prepare:win && npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:linux": "npm run binaries:prepare:linux && npm run build && electron-builder --linux AppImage --x64 --publish never",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:check-version": "node scripts/sync-release-version.mjs --check",
    "release:verify-artifacts": "node scripts/verify-release-artifacts.mjs",
    "test:release-artifacts": "node scripts/test-verify-release-artifacts.mjs",
    "website:dev": "npm run dev --prefix website",
    "website:build": "npm run build --prefix website"
  },
  "build": {
    "appId": "app.coroslink",
    "productName": "CorosLink",
    "publish": {
      "provider": "github",
      "owner": "JunAkerBuilds",
      "repo": "CorosLink"
    },
    "icon": "build/icon.png",
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "identity": "-"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "spotify-web-api-node": "^5.0.2",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/spotify-web-api-node": "^5.0.11",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "ffmpeg-static": "^5.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
