{
  "name": "coros-desktop-app",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial COROS desktop music manager built with Electron, React, and Vite.",
  "author": "COROS Desktop Contributors",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "binaries:prepare": "node scripts/prepare-binaries.mjs",
    "binaries:prepare:win": "node scripts/prepare-binaries.mjs --platform=win32 --arch=x64",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "smoke:watch": "npm run build:electron && node scripts/smoke-watch-service.mjs",
    "start": "npm run build && electron .",
    "icons:generate": "node scripts/generate-icons.mjs",
    "rebuild": "electron-builder install-app-deps",
    "dist": "npm run binaries:prepare && npm run build && electron-builder",
    "dist:mac": "npm run binaries:prepare && npm run build && electron-builder --mac dmg",
    "dist:win": "npm run binaries:prepare:win && npm run build && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "app.coros.desktop",
    "productName": "COROS Desktop",
    "icon": "build/icon.png",
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/spotify-web-api-node": "^5.0.11",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "ffmpeg-static": "^5.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
